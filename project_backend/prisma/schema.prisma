// ─────────────────────────────────────────────────────────────
//  TransitOps — Prisma Schema
//  Database: PostgreSQL (Prisma Postgres)
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════
//  ENUMS
// ═════════════════════════════════════════════════════════════

enum UserRole {
  SUPER_ADMIN       // Full system access
  FLEET_MANAGER     // Manage vehicles, drivers, trips
  DRIVER            // Own trips and profile only
  SAFETY_OFFICER    // Read all; manage maintenance & inspections
  FINANCIAL_ANALYST // Read all; manage expenses & fuel logs
}

enum VehicleStatus {
  AVAILABLE    // Ready to be assigned
  ON_TRIP      // Currently assigned to an active trip
  IN_SHOP      // Under maintenance / repair
  RETIRED      // Decommissioned — no new assignments allowed
}

enum VehicleType {
  BUS
  MINIBUS
  VAN
  TRUCK
  CAR
  MOTORCYCLE
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum LicenseClass {
  A    // Motorcycle
  B    // Light vehicle
  C    // Heavy vehicle
  D    // Bus / public transport
  E    // Articulated / trailer
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DELAYED
}

enum MaintenanceType {
  ROUTINE        // Scheduled service
  REPAIR         // Unplanned breakdown fix
  INSPECTION     // Safety / compliance check
  TYRE           // Tyre change / rotation
  BODY_WORK      // Accident / cosmetic repair
  ELECTRICAL
  OTHER
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  FUEL
  MAINTENANCE
  TOLL
  PERMIT
  INSURANCE
  SALARY
  FINE
  PARKING
  CLEANING
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  REIMBURSED
}

// ═════════════════════════════════════════════════════════════
//  USER
// ═════════════════════════════════════════════════════════════

model User {
  id           String    @id @default(uuid()) @db.Uuid

  /// Clerk's immutable user ID — primary external identity anchor
  clerkId      String    @unique @db.VarChar(64)

  email        String    @unique @db.VarChar(255)
  firstName    String    @db.VarChar(100)
  lastName     String    @db.VarChar(100)
  phone        String?   @unique @db.VarChar(20)
  avatarUrl    String?

  role         UserRole  @default(DRIVER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  // Soft delete
  deletedAt    DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  driver           Driver?
  expenses         Expense[]
  approvedExpenses Expense[] @relation("ExpenseApprover")

  @@index([clerkId])
  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

// ═════════════════════════════════════════════════════════════
//  VEHICLE
// ═════════════════════════════════════════════════════════════

model Vehicle {
  id                 String        @id @default(uuid()) @db.Uuid
  /// Unique registration / plate number  e.g. "MH12AB1234"
  registrationNumber String        @unique @db.VarChar(20)
  make               String        @db.VarChar(100)   // e.g. Tata, Volvo
  model              String        @db.VarChar(100)   // e.g. Starbus, 9400
  year               Int
  type               VehicleType
  fuelType           FuelType
  status             VehicleStatus @default(AVAILABLE)
  capacity           Int           // Passenger or cargo capacity
  color              String?       @db.VarChar(50)
  chassisNumber      String        @unique @db.VarChar(50)
  engineNumber       String        @unique @db.VarChar(50)
  insuranceExpiry    DateTime?
  permitExpiry       DateTime?
  fitnessExpiry      DateTime?     // Vehicle fitness certificate
  odometer           Int           @default(0)        // km — updated on each trip/fuel log
  imageUrl           String?

  // Soft delete
  deletedAt          DateTime?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  drivers            Driver[]
  trips              Trip[]
  maintenanceLogs    Maintenance[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@index([type])
  @@index([deletedAt])
  @@map("vehicles")
}

// ═════════════════════════════════════════════════════════════
//  DRIVER
//  One-to-one extension of User (role = DRIVER)
// ═════════════════════════════════════════════════════════════

model Driver {
  id               String       @id @default(uuid()) @db.Uuid

  // Link to User account
  userId           String       @unique @db.Uuid
  user             User         @relation(fields: [userId], references: [id])

  // Currently assigned vehicle (nullable — driver may be unassigned)
  vehicleId        String?      @db.Uuid
  vehicle          Vehicle?     @relation(fields: [vehicleId], references: [id])

  licenseNumber    String       @unique @db.VarChar(50)
  licenseClass     LicenseClass
  licenseExpiry    DateTime
  status           DriverStatus @default(AVAILABLE)
  experience       Int          @default(0)  // years
  address          String?      @db.Text
  emergencyContact String?      @db.VarChar(20)
  rating           Decimal      @default(5.0)  @db.Decimal(3, 2)
  totalTrips       Int          @default(0)

  /// Composite safety score 0–100 recalculated after each completed trip.
  /// Factors: on-time %, incident rate, license validity, suspension history.
  safetyScore      Decimal      @default(100.0) @db.Decimal(5, 2)

  // Soft delete
  deletedAt        DateTime?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  trips            Trip[]

  @@index([status])
  @@index([vehicleId])
  @@index([licenseExpiry])
  @@index([deletedAt])
  @@map("drivers")
}

// ═════════════════════════════════════════════════════════════
//  TRIP
// ═════════════════════════════════════════════════════════════

model Trip {
  id               String     @id @default(uuid()) @db.Uuid

  // Vehicle and driver are required at scheduling time
  vehicleId        String     @db.Uuid
  vehicle          Vehicle    @relation(fields: [vehicleId], references: [id])

  driverId         String     @db.Uuid
  driver           Driver     @relation(fields: [driverId], references: [id])

  origin           String     @db.VarChar(255)
  destination      String     @db.VarChar(255)

  // Optional geo coordinates for origin / destination
  originLat        Decimal?   @db.Decimal(10, 7)
  originLng        Decimal?   @db.Decimal(10, 7)
  destinationLat   Decimal?   @db.Decimal(10, 7)
  destinationLng   Decimal?   @db.Decimal(10, 7)

  status           TripStatus @default(SCHEDULED)
  scheduledAt      DateTime
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  cancellationNote String?    @db.Text

  distanceKm       Decimal?   @db.Decimal(8, 2)   // filled on completion
  durationMinutes  Int?                             // filled on completion

  odometerStart    Int?       // km at trip start
  odometerEnd      Int?       // km at trip end — used to update Vehicle.odometer

  notes            String?    @db.Text

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // Relations
  expenses         Expense[]

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([scheduledAt])
  @@map("trips")
}

// ═════════════════════════════════════════════════════════════
//  MAINTENANCE
// ═════════════════════════════════════════════════════════════

model Maintenance {
  id            String            @id @default(uuid()) @db.Uuid

  vehicleId     String            @db.Uuid
  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])

  type          MaintenanceType
  status        MaintenanceStatus @default(SCHEDULED)

  title         String            @db.VarChar(255)
  description   String?           @db.Text

  vendor        String?           @db.VarChar(255)  // Garage / service centre name
  vendorContact String?           @db.VarChar(20)

  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?

  odometerAtService Int?          // km when maintenance was done

  // Cost breakdown
  partsCost     Decimal?          @db.Decimal(12, 2)
  labourCost    Decimal?          @db.Decimal(12, 2)
  totalCost     Decimal?          @db.Decimal(12, 2)

  // Next service reminder
  nextServiceAt DateTime?
  nextServiceKm Int?

  invoiceUrl    String?           // Stored document / image URL
  notes         String?           @db.Text

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  expenses      Expense[]

  @@index([vehicleId])
  @@index([type])
  @@index([status])
  @@index([scheduledAt])
  @@map("maintenance_logs")
}

// ═════════════════════════════════════════════════════════════
//  FUEL LOG
// ═════════════════════════════════════════════════════════════

model FuelLog {
  id              String   @id @default(uuid()) @db.Uuid

  vehicleId       String   @db.Uuid
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id])

  fuelType        FuelType
  /// Litres / kWh filled
  quantity        Decimal  @db.Decimal(8, 2)
  /// Price per unit (litre / kWh)
  pricePerUnit    Decimal  @db.Decimal(8, 2)
  totalCost       Decimal  @db.Decimal(12, 2)

  odometerAtFill  Int      // km — enables mileage calculation
  stationName     String?  @db.VarChar(255)
  stationLocation String?  @db.VarChar(255)

  filledAt        DateTime @default(now())
  receiptUrl      String?  // Stored receipt image URL

  notes           String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  expense         Expense?

  @@index([vehicleId])
  @@index([filledAt])
  @@map("fuel_logs")
}

// ═════════════════════════════════════════════════════════════
//  EXPENSE
//  Central ledger — every money-out event links here.
//  Polymorphic via optional FKs: tripId | maintenanceId | fuelLogId
// ═════════════════════════════════════════════════════════════

model Expense {
  id              String          @id @default(uuid()) @db.Uuid

  category        ExpenseCategory
  status          ExpenseStatus   @default(PENDING)

  amount          Decimal         @db.Decimal(12, 2)
  currency        String          @default("INR") @db.VarChar(3)
  description     String?         @db.Text

  // Who incurred / submitted the expense
  submittedById   String          @db.Uuid
  submittedBy     User            @relation(fields: [submittedById], references: [id])

  // Who approved / rejected (nullable until actioned)
  approvedById    String?         @db.Uuid
  approvedBy      User?           @relation("ExpenseApprover", fields: [approvedById], references: [id])
  actionedAt      DateTime?
  rejectionReason String?         @db.Text

  // Optional source links (at most one should be set)
  vehicleId       String?         @db.Uuid
  vehicle         Vehicle?        @relation(fields: [vehicleId], references: [id])

  tripId          String?         @db.Uuid
  trip            Trip?           @relation(fields: [tripId], references: [id])

  maintenanceId   String?         @db.Uuid
  maintenance     Maintenance?    @relation(fields: [maintenanceId], references: [id])

  fuelLogId       String?         @unique @db.Uuid  // 1-to-1 with FuelLog
  fuelLog         FuelLog?        @relation(fields: [fuelLogId], references: [id])

  receiptUrl      String?         // Stored receipt image URL
  incurredAt      DateTime        @default(now())

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([category])
  @@index([status])
  @@index([submittedById])
  @@index([vehicleId])
  @@index([tripId])
  @@index([maintenanceId])
  @@index([incurredAt])
  @@map("expenses")
}
